{
  "name": "inventaire-informatique",
  "version": "1.0.0",
  "description": "Inventaire du matériel informatique",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.inventaire.informatique",
    "productName": "Inventaire Informatique",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerLanguages": ["fr_FR"],
      "language": "1036"
    },
    "files": [
      "main.js",
      "src/**/*",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
